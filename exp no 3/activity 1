def calculate_emi(P, annual_rate, years):
    r = annual_rate / (12 * 100)   # monthly interest rate
    n = years * 12                 # number of months

    emi = (P * r * (1 + r)**n) / ((1 + r)**n - 1)
    return emi

# Example
print("EMI:", calculate_emi(100000, 10, 2))
